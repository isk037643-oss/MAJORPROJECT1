<% layout("/layouts/boilerplate") -%>
<div class="row">
  <div class="col-md-8 offset-3">
    <h3><%= listing.title %></h3>
    <div class="card col-md-6 show-card listing-card">
      <img src="<%= listing.image %>" alt="image" />

      <div class="card-body">
        <p class="card-text"> <i> <%=listing.owner.username %></i></p>  <!--notun j listing tar user name show korbe  -->
          
        <p class="card-text"><%= listing.description %></p>
        <p class="card-text"> &#8377; <%= listing.price.toLocaleString("en-IN")%> </p>
        <p class="card-text"><%= listing.location%></p>
        <p class="card-text"><%= listing.country%> </p>  
      </div>
    </div>
  </div>
 
<% if(currUser && listing.owner._id.equals(currUser._id)) { %> <!-- login thakte hobe r jodi listing ar owner ar id jodi current user ar id same hoi tober edit, delete button dekha jabe -->
  <div class="btns">
    <a
      href="/listings/<%=listing.id%>/edit"
      class="btn btn-dark col-1 offset-3"
      id="sk"
      >edit</a>
    

    <form method="POST" action="/listings/<%= listing.id%>?_method=DELETE">
      <button class="btn btn-dark offset-4">Delete</button>
    </form>
  </div>
<% }  %>

  <div class="col-8 offset-3 mb-3"> <!--Review section ata-->
    <hr>
    <% if(currUser) { %>     <!-- jodi current user login thake  tobei review korte parbe-->
    <h4>Leave a Review</h4>
    <form  method="POST" action="/listings/<%= listing.id %>/reviews" novalidate class="needs-validation">
      <div class="mb-3 mt-3">
        <label for="rating" class="form-label">Rating</label>
        <input type="range" min="1" max="5" id="rating" name="review[rating]" class="form-range"/>
      </div>
      <div class="mb-3 mt-3">
        <label for="comment" class="form-label">Comment</label>
        <textarea
          name="review[comment]"
          id="comment"
          cols="20"
          rows="5"
          class="form-control"
          required
        ></textarea>
        <div class="invalid-feedback">Please submit some comments for review</div>  <!--ata tohon hone jolhon form ar modhe novalidate korbo r  class="needs-validation" korbo tokhon. ai gulo korle empty jokhon thakbe tokhon hobe submit hobe na -->
      </div>
      <button class="btn btn-outline-dark">Submit</button>
    </form>
    <% } %>

    <hr />
    <h4>All Reviews</h4>
    <div class="row"> <!-- protita review k akta row te niye aslam jate akta review ses hole r akta suru hoi same row te-->
     <% for(review of listing.reviews) {%>
      <div class="card col-5 ms-3 mb-3" >
        <div class="card-body">
          <h5 class="card-title"><%= review.author.username %></h5>  <!--je review korbe sei author ar name print hobe-->
          <p class="card-text"><%= review.comment%></p>
          <p class="card-text"><%= review.rating%> Stars</p>
        </div>
        <form  class=" mb-3" method="POST" action="/listings/<%= listing._id %>/reviews/<%=review._id %>?_method=DELETE">
          <button class="btn btn-sm btn-dark">Delete</button>
        </form>
      </div>
      <% } %> 
    </div>
    </div>



    
  </div>
</div>
